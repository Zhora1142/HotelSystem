<Window x:Class="HotelSystem.WPF.AddRoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding OperationTitle}" Height="300" Width="420"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Номер комнаты:" Margin="0,0,10,10" VerticalAlignment="Center"/>
        <TextBox Grid.Column="1" Margin="0,0,0,10" Text="{Binding Number, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="1" Text="Этаж:" Margin="0,0,10,10" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Text="{Binding Floor, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="2" Text="Тип номера:" Margin="0,0,10,10" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,10"
                  ItemsSource="{Binding RoomTypes}"
                  DisplayMemberPath="Name"
                  SelectedItem="{Binding SelectedRoomType}"
                  IsEnabled="{Binding IsRoomTypeSelectionEnabled}"/>

        <TextBlock Grid.Row="3" Text="Статус:" Margin="0,0,10,10" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,10"
                  ItemsSource="{Binding Statuses}"
                  DisplayMemberPath="Value"
                  SelectedValuePath="Key"
                  SelectedValue="{Binding SelectedStatus}"
                  IsEnabled="{Binding IsStatusSelectionEnabled}"/>

        <TextBlock Grid.Row="4" Text="Примечание:" Margin="0,0,10,10" VerticalAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,10" Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Сохранить"
                    Width="100"
                    Height="32"
                    Margin="0,0,10,0"
                    IsDefault="True"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button Content="Отмена" Width="100" Height="32" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>

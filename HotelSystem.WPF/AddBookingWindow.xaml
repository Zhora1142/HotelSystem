<Window x:Class="HotelSystem.WPF.AddBookingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание бронирования" Height="460" Width="720"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Клиент:" Margin="0,0,10,10" VerticalAlignment="Center"/>
        <ComboBox Grid.Column="1" Margin="0,0,0,10"
                  ItemsSource="{Binding Clients}"
                  DisplayMemberPath="FullName"
                  SelectedItem="{Binding SelectedClient}"/>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal">
            <TextBlock Text="Заезд:" Width="60" VerticalAlignment="Center"/>
            <DatePicker SelectedDate="{Binding CheckInDate}" Width="150" Margin="0,0,20,0"/>
            <TextBlock Text="Выезд:" Width="60" VerticalAlignment="Center"/>
            <DatePicker SelectedDate="{Binding CheckOutDate}" Width="150" Margin="0,0,20,0"/>
            <Button Content="Обновить номера" Width="150" Command="{Binding RefreshRoomsCommand}"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Примечание:" Margin="0,10,10,10" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,10,0,10" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"/>

        <DataGrid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,10,0,10"
                  ItemsSource="{Binding AvailableRooms}" SelectedItem="{Binding SelectedRoom}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер" Binding="{Binding Number}" Width="100"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding RoomTypeName}" Width="180"/>
                <DataGridTextColumn Header="Этаж" Binding="{Binding Floor}" Width="80"/>
                <DataGridTextColumn Header="Вместимость" Binding="{Binding Capacity}" Width="110"/>
                <DataGridTextColumn Header="Цена за ночь" Binding="{Binding PricePerNight, StringFormat={}{0:N2}}" Width="130"/>
                <DataGridTextColumn Header="Примечание" Binding="{Binding Note}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить"
                    Width="100"
                    Height="32"
                    Margin="0,0,10,0"
                    IsDefault="True"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button Content="Отмена" Width="100" Height="32" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>

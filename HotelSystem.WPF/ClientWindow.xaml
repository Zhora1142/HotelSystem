<Window x:Class="HotelSystem.WPF.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HotelSystem - Личный кабинет клиента" Height="620" Width="980"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding HeaderText}" FontSize="22" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,16"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Bookings}" SelectedItem="{Binding SelectedBooking}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер" Binding="{Binding RoomNumber}" Width="80"/>
                <DataGridTextColumn Header="Тип номера" Binding="{Binding RoomTypeName}" Width="150"/>
                <DataGridTextColumn Header="Заезд" Binding="{Binding CheckInDate, StringFormat={}{0:dd.MM.yyyy}}" Width="110"/>
                <DataGridTextColumn Header="Выезд" Binding="{Binding CheckOutDate, StringFormat={}{0:dd.MM.yyyy}}" Width="110"/>
                <DataGridTextColumn Header="Ночей" Binding="{Binding NightsCount}" Width="80"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="100"/>
                <DataGridTextColumn Header="Итого" Binding="{Binding TotalCost, StringFormat={}{0:N2}}" Width="120"/>
                <DataGridTextColumn Header="Примечание" Binding="{Binding Notes}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Обновить" Width="110" Margin="0,0,10,0" Command="{Binding RefreshCommand}"/>
            <Button Content="Новая бронь" Width="130" Margin="0,0,10,0" Command="{Binding CreateBookingCommand}"/>
            <Button Content="Детали" Width="110" Margin="0,0,10,0" Command="{Binding ViewDetailsCommand}"/>
            <Button Content="Выход"
                    Width="110"
                    Command="{Binding LogoutCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>
    </Grid>
</Window>
